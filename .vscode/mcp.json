{
  "servers": {
    "penpot": {
      "type": "http",
      "url": "http://localhost:4401/mcp"
    },
    "playwright": {
        "command": "npx",
        "args": [
            "-y",
            "@playwright/mcp@latest"
        ]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"]
    }
  }
}
